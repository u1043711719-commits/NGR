<!DOCTYPE html>
<html>
<head>
  <title>NGR Trading Dashboard</title>

  <style>
    body{
      margin:0;
      font-family:Arial;
      background:#0b0f14;
      color:white;
    }

    /* TOP BAR */
    .topbar{
      background:linear-gradient(90deg, green, black, red);
      padding:15px;
      text-align:center;
      font-size:22px;
      font-weight:bold;
    }

    /* LAYOUT */
    .container{
      display:flex;
      height:100vh;
    }

    /* SIDEBAR */
    .sidebar{
      width:220px;
      background:#111;
      padding:15px;
    }

    .sidebar h3{
      color:#00ff99;
    }

    .menu{
      margin-top:20px;
    }

    .menu div{
      padding:10px;
      margin:8px 0;
      background:#1a1a1a;
      border-radius:6px;
      cursor:pointer;
    }

    .menu div:hover{
      background:#00ff99;
      color:black;
    }

    /* MAIN */
    .main{
      flex:1;
      padding:20px;
    }

    .cards{
      display:flex;
      gap:15px;
      flex-wrap:wrap;
    }

    .card{
      background:#151b22;
      padding:15px;
      border-radius:10px;
      width:200px;
      border:1px solid #00ff99;
    }

    .card h4{
      color:#00ff99;
    }

    /* CHART AREA */
    .chart{
      margin-top:20px;
      background:#111;
      height:400px;
      border-radius:10px;
      display:flex;
      align-items:center;
      justify-content:center;
      border:1px solid #333;
    }

    button{
      margin-top:10px;
      padding:10px;
      background:#00ff99;
      border:none;
      cursor:pointer;
      width:100%;
      border-radius:5px;
    }

    button:hover{
      background:red;
      color:white;
    }

  </style>
</head>

<body>

<div class="topbar">
  🇦🇫 NGR ACADEMY TRADING DASHBOARD 🇦🇫
</div>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">

    <h3>Menu</h3>

    <div class="menu">
      <div>📊 Crypto</div>
      <div>📈 Forex</div>
      <div>📉 TradingView</div>
      <div>⚡ Binary Options</div>
      <div>💼 Portfolio</div>
    </div>

    <button onclick="logout()">Logout</button>

  </div>

  <!-- MAIN -->
  <div class="main">

    <h2 id="welcome"></h2>

    <div class="cards">

      <div class="card">
        <h4>BTC</h4>
        <p>$ 65,000</p>
      </div>

      <div class="card">
        <h4>ETH</h4>
        <p>$ 3,500</p>
      </div>

      <div class="card">
        <h4>Forex</h4>
        <p>USD/EUR</p>
      </div>

      <div class="card">
        <h4>Market</h4>
        <p>Live Data</p>
      </div>

    </div>

    <!-- CHART AREA -->
    <div class="chart">

      <!-- TradingView Widget -->
      <p style="color:#888">
        📊 Trading Chart Area (You can later connect TradingView widget here)
      </p>

    </div>

  </div>

</div>

<script>
const user = localStorage.getItem("user");

if(!user){
  window.location.href = "login.html";
}else{
  document.getElementById("welcome").innerText = "Welcome, " + user;
}

function logout(){
  localStorage.removeItem("user");
  window.location.href = "login.html";
}
</script>

</body>
</html>